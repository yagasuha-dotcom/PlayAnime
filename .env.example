# Ganti kalau domain Samehadaku berubah (situs ini sering pindah domain)
# Opsional — kalau kosong, sistem auto-coba daftar domain kandidat di lib/scraper.ts
SAMEHADAKU_BASE_URL=

# Supabase — ambil dari Project Settings > API di dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxx

# Adsterra — publisher key buat ad-reward (opsional, kosong = mode simulasi timer)
NEXT_PUBLIC_ADSTERRA_KEY=
